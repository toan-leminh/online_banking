extends layouts/main

block title
    div.d-flex.p-3
        a.btn.btn-secondary.btn-sm.mb-3
            i.bi.bi-arrow-left Back to Landing
    div.p-3.pb-md-4.mx-auto.text-center
        h1.display-4.fw-normal Complete registration
        //- p.fs-5.text-muted Create an User

block content
    if data && data.message
        div.alert.alert-success
            h2 Success!
            p= data.message
            p Welcome to Online Banking system, 
                strong #{data.username}!
    
        a.btn.btn-primary.text-center(href="/login") Move to Login Page