extends ../layouts/user

block title
    div.d-flex.p-3
        a.btn.btn-secondary.btn-sm(href="/user/accounts")
            i.bi.bi-arrow-left Back to Accounts

    div.p-3.pb-md-4.mx-auto.text-center
        h1.display-4.fw-normal Edit Account

block content
    if errors.general
        div.alert.alert-danger(role="alert")
            span = errors.general

    form(action="/user/accounts/" + data.account._id + "/edit", method="POST")
        input(type="hidden" name="_csrf" value=csrfToken)
        div.mb-3
            label(for="account_name") Account Name
            input.form-control(name="account_name", value=(data.account.account_name || ''), class=(errors.account_name ? 'is-invalid' : ''))
            if errors.account_name
                div.invalid-feedback #{errors.account_name}

        div.mb-3
            label(for="address") Address
            input.form-control(name="address", value=(data.account.address || ''), class=(errors.address ? 'is-invalid' : ''))
            if errors.address
                div.invalid-feedback #{errors.address}

        div.mb-3
            label(for="phone_number") Phone Number
            input.form-control(name="phone_number", value=(data.account.phone_number || ''), class=(errors.phone_number ? 'is-invalid' : ''))
            if errors.phone_number
                div.invalid-feedback #{errors.phone_number}
        
        button.btn.btn-primary(type="submit") Edit Account